@using GameTracker.Shared.Components.Shared.Dialogs
@using GameTracker.Shared.Features.Common.Dtos
@using GameTracker.Shared.Features.Platforms
@using GameTracker.Shared.State
@using GameTracker.Shared.UI.Enums
@using GameTracker.Shared.UI.Helpers
@using GameTracker.Shared.UI.Models
@inherits AppComponentBase

<AppDialogShell Title="Filters" Icon="@Icons.Material.Filled.FilterList"
                ConfirmText="Appliquer"
                OnConfirm="@Confirm"
                Style="min-width: 35%">
    <MudGrid Class="align-center" Spacing="3">

        <MudItem xs="12" md="4">
            <MudText Typo="Typo.subtitle2">
                Platforme :
            </MudText>
        </MudItem>

        <MudItem xs="12" md="8">
            <MudSelect T="string" Variant="Variant.Outlined" @bind-Value="Model.PlatformName" Margin="Margin.Dense">
                @foreach (SelectItemDto<int> platform in Platforms)
                {
                    <MudSelectItem Value="@platform.Text">
                        @platform.Text
                    </MudSelectItem>
                }
            </MudSelect>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudText Typo="Typo.subtitle2">
                Launcher :
            </MudText>
        </MudItem>

        <MudItem xs="12" md="8">
            <MudSelect T="string" @bind-Value="Model.LauncherName"
                       Variant="Variant.Outlined" Margin="Margin.Dense">
                @foreach (SelectItemDto<int> launcher in Launchers)
                {
                    <MudSelectItem Value="@(launcher.Text)">
                        @launcher.Text
                    </MudSelectItem>
                }
            </MudSelect>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudText Typo="Typo.subtitle2">
                Tri :
            </MudText>
        </MudItem>

        <MudItem xs="12" md="8">
            <MudSelect T="GameSortBy" Variant="Variant.Outlined"
                       Margin="Margin.Dense" @bind-Value="Model.SortBy">
                @foreach (SelectItemDto<GameSortBy> item in SelectHelper.GameSortBy
                                  .Where(x => x.Value is GameSortBy.Recent or GameSortBy.Title))
                {
                    <MudSelectItem Value="@item.Value">
                        @item.Text
                    </MudSelectItem>
                }
            </MudSelect>
        </MudItem>
    </MudGrid>
</AppDialogShell>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] [EditorRequired] public WishlistFilterModel Model { get; set; } = new();

    [Inject] private WishlistState WishlistState { get; set; } = null!;
    [Inject] private PlatformService PlatformService { get; set; } = null!;

    private List<SelectItemDto<int>> Platforms { get; set; } = [];
    private List<SelectItemDto<int>> Launchers { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        Platforms = await PlatformService.GetPlatformSelectItemsAsync();
        Launchers = await PlatformService.GetLauncherSelectItemsAsync();
    }

    private void Confirm()
    {
        MudDialog.Close(DialogResult.Ok(Model));
    }

}