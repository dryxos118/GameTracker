@using GameTracker.Shared.Components.Shared
@using GameTracker.Shared.Components.Shared.Dialogs
@using GameTracker.Shared.Features.Common.Dtos
@using GameTracker.Shared.Features.Common.Enums
@using GameTracker.Shared.Features.Platforms
@using GameTracker.Shared.Features.Platforms.Dtos
@using GameTracker.Shared.State
@using GameTracker.Shared.UI.Models
@inherits AppComponentBase

<MudPaper Class="pa-4" Outlined="true">
    <MudStack Spacing="3">

        <PageHeader Title="Launchers" Icon="@Icons.Material.Filled.Apps">
            <HeaderContent>
                <MudIconButton Icon="@Icons.Material.Filled.Add"
                               Color="Color.Primary" Variant="Variant.Filled"
                               Size="Size.Small"
                               OnClick="@AddLauncher"/>
            </HeaderContent>
        </PageHeader>

        <MudDivider/>

        <MudStack Spacing="2">
            @foreach (LauncherListDto launcher in Launchers)
            {
                <MudPaper Class="pa-2 lookup-item" Outlined="true">
                    <MudStack Row="true"
                              AlignItems="AlignItems.Center"
                              Justify="Justify.SpaceBetween">

                        <MudStack Row="true"
                                  AlignItems="AlignItems.Center"
                                  Spacing="3">

                            <MudText Typo="Typo.subtitle2">
                                @launcher.Name
                            </MudText>

                            <MudChip T="string"
                                     Size="Size.Small"
                                     Variant="Variant.Outlined"
                                     Color="@(launcher.TotalGames == MaxGames && MaxGames > 0
                                                ? Color.Warning
                                                : Color.Default)">

                                @if (launcher.TotalGames == MaxGames && MaxGames > 0)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.EmojiEvents"
                                             Size="Size.Small"
                                             Class="me-1"/>
                                }

                                @launcher.TotalGames jeu@(launcher.TotalGames > 1 ? "x" : "")
                            </MudChip>

                        </MudStack>

                        <MudMenu Icon="@Icons.Material.Filled.MoreVert"
                                 Size="Size.Small">
                            <MudMenuItem Icon="@Icons.Material.Filled.Edit"
                                         OnClick="@(async() => await UpdateLauncher(launcher))">
                                Modifier
                            </MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.DeleteOutline"
                                         IconColor="Color.Error"
                                         OnClick="@(async () => await DeleteLauncher(launcher))">
                                Supprimer
                            </MudMenuItem>
                        </MudMenu>
                    </MudStack>
                </MudPaper>
            }
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public List<LauncherListDto> Launchers { get; set; } = [];

    [Inject] private PlatformService PlatformService { get; set; } = null!;
    [Inject] private PlatformState PlatformState { get; set; } = null!;
    [Inject] private IDialogService DialogService { get; set; } = null!;
    [Inject] private ISnackbar Snackbar { get; set; } = null!;

    private int MaxGames => Launchers.Count > 0 ? Launchers.Max(p => p.TotalGames) : 0;

    private async Task AddLauncher()
    {
        DialogParameters parameters = new()
        {
            [nameof(NameFormDialog.Title)] = "Ajouter un launcher",
            [nameof(NameFormDialog.Model)] = new NameFormDto(),
            [nameof(NameFormDialog.ConfirmText)] = "Ajouter"
        };

        IDialogReference dialog = await DialogService.ShowAsync<NameFormDialog>(null, parameters,
            new DialogOptions { CloseOnEscapeKey = false, BackdropClick = false });

        DialogResult? result = await dialog.Result;

        if (result is { Canceled: false, Data: NameFormDto dto })
        {
            await PlatformService.AddAsync(PlatformReferenceType.Launcher, dto);
            Snackbar.Add($"Le launcher '{dto.Name}' a été ajouté.", Severity.Success);
            await PlatformState.ReloadAsync();
        }
    }

    private async Task UpdateLauncher(LauncherListDto launcher)
    {
        DialogParameters parameters = new()
        {
            [nameof(NameFormDialog.Title)] = "Modifier un launcher",
            [nameof(NameFormDialog.Model)] = new NameFormDto { Id = launcher.Id, Name = launcher.Name },
            [nameof(NameFormDialog.ConfirmText)] = "Enregistrer"
        };

        IDialogReference dialog = await DialogService.ShowAsync<NameFormDialog>(null, parameters,
            new DialogOptions { CloseOnEscapeKey = false, BackdropClick = false });

        DialogResult? result = await dialog.Result;

        if (result is { Canceled: false, Data: NameFormDto dto })
        {
            await PlatformService.UpdateAsync(PlatformReferenceType.Platform, dto);
            await PlatformState.ReloadAsync();
        }
    }

    private async Task DeleteLauncher(LauncherListDto launcher)
    {
        AppMessageDialogModel model = new()
        {
            Title = "Confirmation",
            Message = $"Supprimer le launcher \"{launcher.Name}\" ?",
            SubTitle = "Cette action est irréversible.",
            ConfirmText = "Supprimer",
            CancelText = "Annuler",
            Icon = Icons.Material.Filled.Delete,
            Color = Color.Error
        };

        DialogParameters parameters = new()
        {
            [nameof(AppMessageDialog.Model)] = model
        };

        IDialogReference dialog = await DialogService.ShowAsync<AppMessageDialog>(parameters);

        DialogResult? result = await dialog.Result;

        if (result is { Canceled: false })
        {
            OperationResult operationResult = await PlatformService.DeleteAsync(PlatformReferenceType.Launcher, launcher.Id);

            switch (operationResult)
            {
                case OperationResult.Success:
                    Snackbar.Add("Élément supprimé.", Severity.Success);
                    await PlatformState.ReloadAsync();
                    break;
                case OperationResult.InUse:
                    Snackbar.Add("Impossible de supprimer cet élément car il est utilisé par un ou plusieurs jeux.",
                        Severity.Warning);
                    break;
                case OperationResult.NotFound:
                    Snackbar.Add("Element introuvable", Severity.Error);
                    break;
            }
        }
    }
}