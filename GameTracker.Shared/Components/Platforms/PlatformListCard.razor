@using GameTracker.Shared.Components.Shared
@using GameTracker.Shared.Components.Shared.Dialogs
@using GameTracker.Shared.Features.Common.Dtos
@using GameTracker.Shared.Features.Common.Enums
@using GameTracker.Shared.Features.Platforms
@using GameTracker.Shared.Features.Platforms.Dtos
@using GameTracker.Shared.State
@using GameTracker.Shared.UI.Helpers
@using GameTracker.Shared.UI.Models
@inherits AppComponentBase

<MudPaper Class="pa-4" Outlined="true">
    <MudStack Spacing="3">

        <PageHeader Title="Plateformes" Icon="@Icons.Material.Filled.Devices">
            <HeaderContent>
                <MudIconButton Icon="@Icons.Material.Filled.Add"
                               Color="Color.Primary" Variant="Variant.Filled"
                               Size="Size.Small"
                               OnClick="@AddPlatform"/>
            </HeaderContent>
        </PageHeader>

        <MudDivider/>

        <MudStack Spacing="2">
            @foreach (PlatformListDto platform in Platforms)
            {
                <MudPaper Class="pa-2 lookup-item" Outlined="true">
                    <MudStack Row="true"
                              AlignItems="AlignItems.Center"
                              Justify="Justify.SpaceBetween">

                        <MudStack Row="true"
                                  AlignItems="AlignItems.Center"
                                  Spacing="3">

                            <MudText Typo="Typo.subtitle2">
                                @platform.Name
                            </MudText>

                            <MudChip T="string"
                                     Size="Size.Small"
                                     Variant="Variant.Outlined"
                                     Color="@(platform.TotalGames == MaxGames && MaxGames > 0
                                                ? Color.Warning
                                                : Color.Default)">

                                @if (platform.TotalGames == MaxGames && MaxGames > 0)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.EmojiEvents"
                                             Size="Size.Small"
                                             Class="me-1"/>
                                }
                                @platform.TotalGames jeu@(platform.TotalGames > 1 ? "x" : "")
                            </MudChip>

                        </MudStack>

                        <MudMenu Icon="@Icons.Material.Filled.MoreVert"
                                 Size="Size.Small">
                            <MudMenuItem Icon="@Icons.Material.Filled.Edit"
                                         OnClick="@(async () => await UpdatePlatform(platform))">
                                Modifier
                            </MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.DeleteOutline"
                                         IconColor="Color.Error"
                                         OnClick="@(async () => await DeletePlatform(platform))">
                                Supprimer
                            </MudMenuItem>
                        </MudMenu>
                    </MudStack>
                </MudPaper>
            }
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    [Parameter] [EditorRequired] public List<PlatformListDto> Platforms { get; set; } = [];

    [Inject] private PlatformState PlatformState { get; set; } = null!;
    [Inject] private IDialogService DialogService { get; set; } = null!;
    [Inject] private ISnackbar Snackbar { get; set; } = null!;

    private int MaxGames => Platforms.Count > 0 ? Platforms.Max(p => p.TotalGames) : 0;

    private async Task AddPlatform()
    {
        DialogParameters parameters = new()
        {
            [nameof(NameFormDialog.Title)] = "Ajouter une plateforme",
            [nameof(NameFormDialog.Model)] = new NameFormDto(),
            [nameof(NameFormDialog.ConfirmText)] = "Ajouter"
        };

        IDialogReference dialog = await DialogService.ShowAsync<NameFormDialog>(null, parameters,
            new DialogOptions { CloseOnEscapeKey = false, BackdropClick = false });

        DialogResult? result = await dialog.Result;

        if (result is { Canceled: false, Data: NameFormDto dto })
        {
            OperationResult success = await PlatformState.AddAsync(PlatformReferenceType.Platform, dto);

            if (success == OperationResult.Success)
                Snackbar.Add($"{dto.Name} à été ajouté.", Severity.Success);
            else
                Snackbar.Add(MessageHelper.GenericError, Severity.Error);
        }
    }

    private async Task UpdatePlatform(PlatformListDto platform)
    {
        DialogParameters parameters = new()
        {
            [nameof(NameFormDialog.Title)] = "Modifier une plateforme",
            [nameof(NameFormDialog.Model)] = new NameFormDto { Id = platform.Id, Name = platform.Name },
            [nameof(NameFormDialog.ConfirmText)] = "Enregistrer"
        };

        IDialogReference dialog = await DialogService.ShowAsync<NameFormDialog>(null, parameters,
            new DialogOptions { CloseOnEscapeKey = false, BackdropClick = false });

        DialogResult? result = await dialog.Result;

        if (result is { Canceled: false, Data: NameFormDto dto })
        {
            OperationResult success = await PlatformState.UpdateAsync(PlatformReferenceType.Platform, dto);

            if (success == OperationResult.Success)
                Snackbar.Add($"{dto.Name} à été modifier.", Severity.Success);
            else if (success == OperationResult.NotFound)
                Snackbar.Add(message: MessageHelper.NotFoundError, Severity.Error);
            else
                Snackbar.Add(MessageHelper.GenericError, Severity.Error);
        }
    }

    private async Task DeletePlatform(PlatformListDto platform)
    {
        AppMessageDialogModel model = new()
        {
            Title = "Confirmation",
            Message = $"Supprimer la plateforme \"{platform.Name}\" ?",
            SubTitle = "Cette action est irréversible.",
            ConfirmText = "Supprimer",
            CancelText = "Annuler",
            Icon = Icons.Material.Filled.Delete,
            Color = Color.Error
        };

        DialogParameters parameters = new()
        {
            [nameof(AppMessageDialog.Model)] = model
        };

        IDialogReference dialog = await DialogService.ShowAsync<AppMessageDialog>(parameters);

        DialogResult? result = await dialog.Result;

        if (result is { Canceled: false })
        {
            OperationResult operationResult = await PlatformState.DeleteAsync(PlatformReferenceType.Platform, platform.Id);

            switch (operationResult)
            {
                case OperationResult.Success:
                    Snackbar.Add($"{platform.Name} à été supprimé.", Severity.Success);
                    break;
                case OperationResult.InUse:
                    Snackbar.Add($"Impossible de supprimer {platform.Name} car il est utilisé par un ou plusieurs jeux.",
                        Severity.Warning);
                    break;
                case OperationResult.NotFound:
                    Snackbar.Add(MessageHelper.NotFoundError, Severity.Error);
                    break;
                case OperationResult.Error:
                default:
                    Snackbar.Add(MessageHelper.GenericError, Severity.Error);
                    break;
            }
        }
    }

}