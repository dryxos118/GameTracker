@inherits AppComponentBase

<MudDialog Style="@Style">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
            <MudIcon Icon="@Icon" Color="@Color"/>
            
            <MudText Typo="Typo.h6">
                @Title
            </MudText>
        </MudStack>
    </TitleContent>
    
    <DialogContent>
        @ChildContent
    </DialogContent>
    
    <DialogActions>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
            <MudButton Variant="Variant.Outlined" OnClick="@Cancel">
                @CancelText
            </MudButton>
            
            <MudButton Variant="Variant.Filled" Color="@Color" OnClick="@Confirm">
                @ConfirmText
            </MudButton>
        </MudStack>
    </DialogActions>
</MudDialog>