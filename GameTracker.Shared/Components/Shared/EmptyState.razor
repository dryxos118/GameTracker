@* Shared/Components/Shared/EmptyState.razor *@

<MudPaper Outlined="@Outlined"
          Class="@($"pa-6 empty-state {Class}")">

    <MudStack AlignItems="AlignItems.Center"
              Justify="Justify.Center"
              Spacing="2"
              Class="empty-state-content">

        <MudIcon Icon="@Icon"
                 Color="@Color"
                 Class="empty-state-icon" />

        <MudText Typo="Typo.h6" Align="Align.Center">
            @Title
        </MudText>

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <MudText Typo="Typo.body2"
                     Color="Color.Secondary"
                     Align="Align.Center"
                     Class="empty-state-message">
                @Message
            </MudText>
        }

        @if (ChildContent is not null)
        {
            <div class="mt-2">
                @ChildContent
            </div>
        }

    </MudStack>

</MudPaper>

@code {
    [Parameter] public string Title { get; set; } = "Aucun élément";

    [Parameter] public string? Message { get; set; }

    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.Inbox;

    [Parameter] public Color Color { get; set; } = Color.Primary;

    [Parameter] public bool Outlined { get; set; } = true;

    [Parameter] public string? Class { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }
}