@using GameTracker.Shared.Features.Common.Dtos
@inherits AppComponentBase

<AppDialogShell Title="@Title"
                ConfirmText="@ConfirmText"
                OnConfirm="@Submit"
                Style="min-width: 35%">
    
    <MudForm @ref="_form">
        <MudGrid Class="align-center" Spacing="3">
            <MudItem xs="12" md="3">
                <MudText Typo="Typo.subtitle2" Class="field-label field-label-required">
                    Nom :
                </MudText>
            </MudItem>

            <MudItem xs="12" md="9">
                <MudTextField @bind-Value="Model.Name"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Required="true"
                              RequiredError="Le nom est obligatoire."/>
            </MudItem>
        </MudGrid>
        
    </MudForm>
</AppDialogShell>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter, EditorRequired] public string Title { get; set; }
    [Parameter, EditorRequired] public NameFormDto Model { get; set; } = new();
    [Parameter] public string ConfirmText { get; set; } = "Enregistrer";

    private MudForm? _form;

    private async Task Submit()
    {
        if (_form is null)
            return;

        await _form.ValidateAsync();
        
        if(!_form.IsValid)
            return;
        
        MudDialog.Close(DialogResult.Ok(Model));
    }
}