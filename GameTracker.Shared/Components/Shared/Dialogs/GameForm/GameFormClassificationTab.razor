@using GameTracker.Shared.Domain.Enums
@using GameTracker.Shared.Features.Common.Dtos
@using GameTracker.Shared.Features.Games.Dtos
@using GameTracker.Shared.UI.Helpers
@inherits AppComponentBase

<MudGrid Spacing="3" Class="align-center">

    <MudItem xs="12" md="3">
        <MudText Typo="Typo.subtitle2" Class="field-label field-label-required">
            Plateforme :
        </MudText>
    </MudItem>

    <MudItem xs="12" md="9">
        <MudSelect T="int?" Variant="Variant.Outlined"
                   @bind-Value="Model.PlatformId"
                   Margin="Margin.Dense"
                   ReadOnly="@ReadOnly">
            @foreach (SelectItemDto<int> platform in Platforms)
            {
                <MudSelectItem Value="@((int?)platform.Value)">
                    @platform.Text
                </MudSelectItem>
            }
        </MudSelect>
    </MudItem>

    <MudItem xs="12" md="3">
        <MudText Typo="Typo.subtitle2" Class="field-label">
            Launcher :
        </MudText>
    </MudItem>

    <MudItem xs="12" md="9">
        <MudSelect T="int?"
                   @bind-Value="Model.LauncherId"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   ReadOnly="@ReadOnly">
            @foreach (SelectItemDto<int> launcher in Launchers)
            {
                <MudSelectItem Value="@((int?)launcher.Value)">
                    @launcher.Text
                </MudSelectItem>
            }
        </MudSelect>
    </MudItem>

    <MudItem xs="12" md="3">
        <MudText Typo="Typo.subtitle2" Class="field-label">
            Modes :
        </MudText>
    </MudItem>

    <MudItem xs="12" md="9">
        <MudSelect T="GameMode" @bind-Value="Model.Modes"
                   Variant="Variant.Outlined" Margin="Margin.Dense"
                   ReadOnly="@ReadOnly">
            @foreach (SelectItemDto<GameMode> mode in SelectHelper.GameModes)
            {
                <MudSelectItem Value="@mode.Value">
                    @mode.Text
                </MudSelectItem>
            }
        </MudSelect>
    </MudItem>

    <MudItem xs="12" md="3" Class="field-label">
        <MudText Typo="Typo.subtitle2">
            Genres :
        </MudText>
    </MudItem>

    <MudItem xs="12" md="9">
        <MudSelect T="int"
                   Variant="Variant.Outlined" Margin="Margin.Dense"
                   MultiSelection="true" SelectedValues="Model.GenreIds"
                   SelectedValuesChanged="OnGenresChanged"
                   ToStringFunc="GetGenreName"
                   ReadOnly="@ReadOnly">
            @foreach (SelectItemDto<int> genre in Genres)
            {
                <MudSelectItem Value="@genre.Value">
                    @genre.Text
                </MudSelectItem>
            }
        </MudSelect>
    </MudItem>

    <MudItem xs="12" md="3">
        <MudText Typo="Typo.subtitle2" Class="field-label">
            Tags :
        </MudText>
    </MudItem>

    <MudItem xs="12" md="9">
        <MudSelect T="int"
                   Variant="Variant.Outlined" Margin="Margin.Dense"
                   MultiSelection="true" SelectedValues="Model.TagIds"
                   SelectedValuesChanged="OnTagsChanged"
                   ToStringFunc="GetTagName"
                   ReadOnly="@ReadOnly">
            @foreach (SelectItemDto<int> tag in Tags)
            {
                <MudSelectItem Value="@tag.Value">
                    @tag.Text
                </MudSelectItem>
            }
        </MudSelect>
    </MudItem>
</MudGrid>

@code {
    [Parameter] [EditorRequired] public GameFormDto Model { get; set; } = null!;
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public List<SelectItemDto<int>> Platforms { get; set; } = [];
    [Parameter] public List<SelectItemDto<int>> Launchers { get; set; } = [];
    [Parameter] public List<SelectItemDto<int>> Genres { get; set; } = [];
    [Parameter] public List<SelectItemDto<int>> Tags { get; set; } = [];

    private string GetGenreName(int id)
    {
        return Genres.FirstOrDefault(x => x.Value == id)?.Text ?? string.Empty;
    }

    private void OnGenresChanged(IReadOnlyCollection<int>? values)
    {
        if (values is not null)
            Model.GenreIds = values.ToList();
    }

    private string GetTagName(int id)
    {
        return Tags.FirstOrDefault(x => x.Value == id)?.Text ?? string.Empty;
    }

    private void OnTagsChanged(IReadOnlyCollection<int>? values)
    {
        if (values is not null)
            Model.TagIds = values.ToList();
    }

}