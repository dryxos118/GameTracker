@using GameTracker.Shared.Domain.Enums
@using GameTracker.Shared.Features.Common.Dtos
@using GameTracker.Shared.Features.Games.Dtos
@using GameTracker.Shared.UI.Helpers
<MudGrid Class="align-center" Spacing="3">

    <MudItem xs="12" md="3">
        <MudText Typo="Typo.subtitle2" Class="field-label field-label-required">
            Statut :
        </MudText>
    </MudItem>

    <MudItem xs="12" md="9">
        <MudSelect T="GameLibraryStatus"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   @bind-Value="Model.LibraryStatus"
                   ReadOnly="true">

            @foreach (SelectItemDto<GameLibraryStatus> item in SelectHelper.GameLibraryStatuses)
            {
                <MudSelectItem Value="@item.Value">
                    @item.Text
                </MudSelectItem>
            }

        </MudSelect>
    </MudItem>

    <MudItem xs="12" md="3">
        <MudText Typo="Typo.subtitle2" Class="field-label field-label-required">
            Progression :
        </MudText>
    </MudItem>

    <MudItem xs="12" md="9">
        <MudSelect T="GamePlayStatus?"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   @bind-Value="Model.PlayStatus"
                   ReadOnly="@(ReadOnly || IsWishlist)">

            @foreach (SelectItemDto<GamePlayStatus?> item in SelectHelper.GamePlayStatuses)
            {
                <MudSelectItem Value="@item.Value">
                    @item.Text
                </MudSelectItem>
            }

        </MudSelect>
    </MudItem>

    <MudItem xs="12" md="3">
        <MudText Typo="Typo.subtitle2" Class="field-label">
            Temps joué (h) :
        </MudText>
    </MudItem>

    <MudItem xs="12" md="9">
        <MudNumericField T="int"
                         Variant="Variant.Outlined"
                         Margin="Margin.Dense"
                         Min="0"
                         HideSpinButtons="true"
                         @bind-Value="Model.PlayedHours"
                         ReadOnly="@(ReadOnly || IsWishlist)"/>
    </MudItem>

    <MudItem xs="12" md="3">
        <MudText Typo="Typo.subtitle2" Class="field-label">
            Note :
        </MudText>
    </MudItem>

    <MudItem xs="12" md="9">
        <MudRating @bind-SelectedValue="Model.Rating" MaxValue="10" ReadOnly="@(ReadOnly || IsWishlist)"/>
    </MudItem>

    <MudItem xs="12" md="3">
        <MudText Typo="Typo.subtitle2" Class="field-label">
            Favori :
        </MudText>
    </MudItem>

    <MudItem xs="12" md="9">
        <MudToggleIconButton @bind-Toggled="Model.IsFavorite"
                             Icon="@Icons.Material.Outlined.FavoriteBorder"
                             ToggledIcon="@Icons.Material.Filled.Favorite"
                             Color="Color.Error"
                             Disabled="@(ReadOnly || IsWishlist)"/>
    </MudItem>

</MudGrid>

@code {
    [Parameter] [EditorRequired] public GameFormDto Model { get; set; } = null!;
    [Parameter] public bool ReadOnly { get; set; }

    private bool IsWishlist => Model.LibraryStatus == GameLibraryStatus.Wishlist;
}