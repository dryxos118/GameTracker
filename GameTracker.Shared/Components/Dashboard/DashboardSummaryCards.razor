@using GameTracker.Shared.Components.Shared
@using GameTracker.Shared.Features.Dashboard.Dtos
<MudGrid Spacing="2">

    <MudItem xs="12" sm="6" md="3">
        <StatCard Title="Wishlist"
                  Value="@Summary.WishlistCount.ToString()"
                  Subtitle="Jeux souhaités"
                  Icon="@Icons.Material.Filled.Bookmark"
                  Color="Color.Secondary"
                  IsLarge="true"/>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <StatCard Title="Temps joué"
                  Value="@($"{Summary.TotalPlayedHours} h")"
                  Subtitle="Temps total"
                  Icon="@Icons.Material.Filled.Schedule"
                  Color="Color.Info"
                  IsLarge="true"/>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <StatCard Title="Plateforme favorite"
                  Value="@Summary.FavoritePlatform"
                  Subtitle="@($"{Summary.FavoritePlatformCount} jeux")"
                  Icon="@Icons.Material.Filled.SportsEsports"
                  Color="Color.Primary"
                  IsLarge="true"/>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <StatCard Title="Bibliothèque"
                  Value="@Summary.TotalGames.ToString()"
                  Subtitle="Jeux enregistrés"
                  Icon="@Icons.Material.Filled.AllInclusive"
                  Color="Color.Success"
                  IsLarge="true"/>
    </MudItem>

</MudGrid>

@code {
    [Parameter][EditorRequired] public DashboardSummaryDto Summary { get; set; } = null!;
}