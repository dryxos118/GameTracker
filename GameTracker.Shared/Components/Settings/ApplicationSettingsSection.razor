@using GameTracker.Shared.Components.Shared
@inherits AppComponentBase

<MudPaper Class="pa-4 settings-section" Outlined="true">
    <MudStack Spacing="4">

        <PageHeader
            Title="@L["Settings.Application.Title"]"
            SubTitle="@L["Settings.Application.Subtitle"]"
            Icon="@Icons.Material.Filled.Info"
            Color="Color.Tertiary"/>

        <MudDivider/>

        <MudGrid Spacing="2">

            <MudItem xs="12" sm="6" md="3">
                <StatCard Title="@L["Settings.Application.Name"]"
                          Value="Game Tracker"
                          Icon="@Icons.Material.Filled.Extension"
                          Color="Color.Primary"/>
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <StatCard Title="@L["Settings.Application.Version"]"
                          Value="1.0.0"
                          Icon="@Icons.Material.Filled.Info"
                          Color="Color.Info"/>
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <StatCard Title="@L["Settings.Application.LocalDatabase"]"
                          Value="SQLite"
                          Icon="@Icons.Material.Filled.Storage"
                          Color="Color.Success"/>
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <StatCard Title="@L["Settings.Application.Stack"]"
                          Value="Blazor .NET 8"
                          Icon="@Icons.Material.Filled.Code"
                          Color="Color.Warning"/>
            </MudItem>

        </MudGrid>

    </MudStack>
</MudPaper>