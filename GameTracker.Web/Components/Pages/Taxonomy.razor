@page "/taxonomy"
@using GameTracker.Shared.Components.Shared
@using GameTracker.Shared.Components.Taxonomy
@inherits AppComponentBase

<PageTitle>Genres & Tags</PageTitle>

<MudStack Spacing="4">
    <PageHeader
        Title="Genres & tags"
        SubTitle="Organisez vos jeux avec des genres et des tags personnalisés."
        Icon="@Icons.Material.Filled.Category"
        Color="Color.Secondary"
        IsLarge="true"/>

    @if (TaxonomyState.IsLoading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary"/>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" md="6">
                <GenreListCard Genres="@TaxonomyState.Genres"/>
            </MudItem>

            <MudItem xs="12" md="6">
                <TagListCard Tags="@TaxonomyState.Tags"/>
            </MudItem>
        </MudGrid>
    }
</MudStack>