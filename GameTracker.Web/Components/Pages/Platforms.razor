@page "/platforms"
@using GameTracker.Shared.Components.Platforms
@using GameTracker.Shared.Components.Shared
@inherits AppComponentBase

<PageTitle>Plateformes & Launchers</PageTitle>

<MudStack Spacing="4">
    <PageHeader
        Title="Plateformes & launchers"
        SubTitle="Gérez les plateformes et les launchers de votre bibliothèque."
        Icon="@Icons.Material.Filled.Devices"
        Color="Color.Secondary" 
        IsLarge="true"/>

    @if (PlatformState.IsLoading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary"/>
    }
    else
    {
        <MudGrid Spacing="4">
            <MudItem xs="12" lg="6">
                <PlatformListCard Platforms="@PlatformState.Platforms" />
            </MudItem>
            
            <MudItem xs="12" lg="6">
                <LauncherListCard Launchers="@PlatformState.Launchers" />
            </MudItem>
        </MudGrid>
    }
</MudStack>