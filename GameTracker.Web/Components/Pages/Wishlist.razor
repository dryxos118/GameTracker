@page "/wishlist"
@using GameTracker.Shared.Components.Shared
@inherits AppComponentBase

<PageTitle>Wishlist</PageTitle>

<MudStack Spacing="4">
    <PageHeader
        Title="Wishlist"
        SubTitle="Suivez les jeux que vous souhaitez ajouter à votre bibliothèque."
        Icon="@Icons.Material.Filled.Favorite"
        Color="Color.Error"
        IsLarge="true">

        <HeaderContent>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add">
                Ajouter à la wishlist
            </MudButton>
        </HeaderContent>
    </PageHeader>

    <MudPaper Class="pa-4" Outlined="true">
        <MudText Typo="Typo.h6">À venir</MudText>

        <MudList T="string" Dense="true">
            <MudListItem>Liste wishlist</MudListItem>
            <MudListItem>Ajout rapide</MudListItem>
            <MudListItem>Suppression</MudListItem>
            <MudListItem>Transfert vers bibliothèque</MudListItem>
            <MudListItem>Filtres et recherche</MudListItem>
        </MudList>
    </MudPaper>
</MudStack>