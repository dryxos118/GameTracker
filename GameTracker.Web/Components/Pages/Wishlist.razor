@page "/wishlist"
@using GameTracker.Shared.Components.Shared
@using GameTracker.Shared.Components.Wishlist
@inherits AppComponentBase

<PageTitle>Wishlist</PageTitle>

<MudStack Spacing="4">
    <PageHeader
        Title="Wishlist"
        SubTitle="@($"{WishlistState.FilteredGames.Count} jeu(x) dans votre liste de souhaits")"
        Icon="@Icons.Material.Filled.Favorite"
        Color="Color.Error"
        IsLarge="true">

        <HeaderContent>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="@OpenCreateDialog">
                Ajouter à la wishlist
            </MudButton>
        </HeaderContent>
    </PageHeader>
    
    <WishlistFilter/>

    @if (!WishlistState.IsLoaded)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary"/>
    }
    else if (WishlistState.WishlistGames.Count == 0)
    {
        <EmptyState Title="Votre liste de souhaits est vide"
                    Message="Ajoutez un jeu à votre wishlist pour commencer."
                    Icon="@Icons.Material.Filled.BookmarkBorder" />
    }
    else if (WishlistState.FilteredGames.Count == 0)
    {
        <EmptyState Title="Aucun jeu trouvé"
                    Message="Essayez de modifier ou réinitialiser vos filtres."
                    Icon="@Icons.Material.Filled.FilterAltOff">
            <MudButton Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.RestartAlt"
                       OnClick="@WishlistState.ResetFilters">
                Réinitialiser les filtres
            </MudButton>
        </EmptyState>
    }
    else
    {
        <WishlistGrid WishlistGames="@WishlistState.FilteredGames"/>
    }
</MudStack>