@inherits AppComponentBase

<MudAppBar Elevation="@Elevation" Dense="true">
    <MudIconButton
        Icon="@Icons.Material.Filled.Menu"
        Edge="Edge.Start"
        Color="Color.Default"
        OnClick="@OnDrawerToggle"/>

    <MudIcon
        Icon="@Icons.Material.Filled.SportsEsports"
        Color="Color.Primary"/>

    <MudText Typo="Typo.h6" Color="Color.Primary" Class="ml-2 font-weight-bold">
        Game Tracker
    </MudText>

    <MudSpacer/>

    <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">
        @_totalGames jeux
    </MudChip>
</MudAppBar>
